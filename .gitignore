# Build outputs
/target/
**/target/
*.rlib
*.rmeta

# One-off cargo command transcripts at workspace root (debugging dumps,
# not source). Cleanup pass 2026-05-06 removed 4 such files.
/cargo-*.txt
/cargo-*.log

# Sub-agent dispatch transcripts (clippy / test output dumps from
# multi-agent sweeps; debugging artifacts, not source).
/_sweep_logs/

# Cargo lockfile is committed at workspace root only
# (members shouldn't commit their own Cargo.lock)
**/Cargo.lock
!/Cargo.lock

# IDE
/.idea/
/.vscode/
*.iml
.vs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Profiling / coverage
/coverage/
*.profraw
*.profdata
flamegraph.svg
perf.data*

# Logs
*.log

# Editor user state
~/.config/rge/

# Cooked artifacts (per-project)
**/target/cook/

# Vendored third-party (kept in tree explicitly via third_party/)
# but build artifacts inside vendored copies are ignored
third_party/**/target/

# Architecture-lints CI artifacts
/tools/architecture-lints/output/

# AI review workflow — schemas are committed, generated artifacts are not
/.ai/*.diff
/.ai/*.json
/.ai/dispatch-*/
/.ai/dispatch.auto-halt
!/.ai/*.schema.json

# Claude Code local state — project .claude/ config (settings.json, hooks/)
# is committed, but per-session worktrees are local-only
/.claude/worktrees/
/.claude/scheduled_tasks.lock

# Local archive of superseded scratch / handoff history (kept out of tree)
/OLD/
/files/
